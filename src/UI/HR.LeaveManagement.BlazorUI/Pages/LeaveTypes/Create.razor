@page "/leavetypes/create"

<h3>Create Leave Type</h3>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-danger">@Message</div>
}

<EditForm Model="LeaveType" OnValidSubmit="CreateLeaveType">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="LeaveType.Name" />
        <ValidationMessage For="@(() => LeaveType.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Default Number of Days</label>
        <InputNumber class="form-control" @bind-Value="LeaveType.DefaultDays" />
        <ValidationMessage For="@(() => LeaveType.DefaultDays)" />
    </div>

    <div class="m-2 d-flex justify-content-end gap-2">
        <a href="/leavetypes" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Leave Type</button>
    </div>
</EditForm>
